{
  "name": "genesisai-demo-server",
  "version": "1.0.0",
  "description": "Demo backend server for Genesis AI Systems portfolio live demos. Proxies requests to OpenAI, Claude, n8n, and Vapi. Enforces production-level rate limiting and CORS.",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "lint": "eslint .",
    "prepare": "echo Genesis AI Systems production demo server ready for Railway."
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Trendell Fordham <info@genesisai.systems>",
  "license": "MIT",
  "homepage": "https://genesisai.systems",
  "repository": {
    "type": "git",
    "url": "https://github.com/prosperouscollection-prog/ai-automation-portfolio"
  },
  "keywords": [
    "Genesis AI Systems",
    "AI automation",
    "demo",
    "Express",
    "OpenAI",
    "Claude",
    "n8n",
    "Vapi",
    "Railway",
    "portfolio"
  ],
  "dependencies": {
    "axios": "^1.6.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.18.2",
    "express-rate-limit": "^6.7.0",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0",
    "uuid": "^9.0.1",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "nodemon": "^3.1.0"
  },
  "railway": {
    "startCommand": "npm start"
  }
}
