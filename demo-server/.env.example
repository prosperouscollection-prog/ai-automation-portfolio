# Genesis AI Systems Demo Server - Example .env
# Copy this file to .env and fill in actual values before running in production.

# ==== PORT SETTINGS ====
PORT=3001

# ==== DOMAIN/CORS ====
# Only allow requests from the live domain
CORS_ORIGIN=https://genesisai.systems

# ==== LOGGING ====
# Directory or service to log API usage
demo_LOG_PATH=./logs/demo-usage.log

# ==== OPENAI (for AI/Chat Widget/Fine-tuned Demo) ====
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# ==== ANTHROPIC/CLAUDE (for RAG Chatbot Demo) ====
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=claude-...
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# ==== GENESIS AI SYSTEMS - N8N (Used by Projects 1, 4, 7) ====
# This is the live automation backend
N8N_WEBHOOK_BASE=https://n8n.genesisai.systems/webhook

# ==== Vapi / Voice Agent (Project 2) ====
# Get your Vapi public + secret from: https://vapi.ai
VAPI_PUBLIC_API_KEY=pk_...
VAPI_SECRET_API_KEY=sk_...
VAPI_ASSISTANT_ID=va_...
# Where to POST incoming call webhook events
VAPI_WEBHOOK_URL=https://n8n.genesisai.systems/webhook/voice-agent-incoming

# ==== GOOGLE SHEETS (used for logging, lead scoring, call logging, etc.) ====
# Google service account credentials - use JSON or path to file
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":...}
GOOGLE_SHEET_PROD_PROJECT1_ID=1XxxSheetID_FOR_LEADSxxx
GOOGLE_SHEET_PROD_VOICE_AGENT_ID=1XxxSheetID_FOR_VOICE_AGENTxx
GOOGLE_SHEET_PROD_VIDEO_ID=1XxxSheetID_FOR_VIDEO_AUTOMATIONxx
# Sheet names as examples:
SHEET_NAME_LEADS=Genesis AI Systems — Leads
SHEET_NAME_VOICE=Genesis AI Systems — Inbound Calls
SHEET_NAME_VIDEO=Genesis AI Systems — Content Calendar

# ==== EMAIL (for notifications, auto-replies, etc.) ====
# Used for sending emails as info@genesisai.systems via SendGrid
SENDGRID_API_KEY=SG.XXXX
EMAIL_FROM=info@genesisai.systems
EMAIL_REPLY_TO=info@genesisai.systems

# ==== TWILIO (optional SMS notifications) ====
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=yyy
TWILIO_FROM_NUMBER=+13134002575
SMS_ALERT_NUMBER=+13134002575

# ==== SECURITY ====
# If you use encryption/signing for secrets, set a server secret here
SERVER_SECRET_KEY=please-set-a-long-random-string

# ==== RATE LIMITING ====
# 10 requests per IP per hour
RATE_LIMIT_WINDOW=3600000
RATE_LIMIT_MAX=10

# ==== BRANDING / METADATA ====
BRAND_NAME=Genesis AI Systems
BRAND_TAGLINE=Done-for-you AI automation for local businesses
FOUNDER_NAME=Trendell Fordham
FOUNDER_EMAIL=info@genesisai.systems
WEBSITE_URL=https://genesisai.systems

# ==== OPTIONAL: RAILWAY ENV (for Railway Deployments) ====
RAILWAY_PUBLIC_DOMAIN=
NODE_ENV=production
