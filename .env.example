# Genesis AI Systems — Environment Template

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_ACCOUNT_BALANCE=
PROMPT_MODEL=gpt-4o
MIN_BALANCE=2.00

# Prompt Deployer Paths
PORTFOLIO_DIR=/Users/genesisai/portfolio
PROMPTS_DIR=/Users/genesisai/portfolio/.github/workflows/prompts

# Notifications
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=your_twilio_from_number
ALERT_PHONE_NUMBER=+13134002575
RESEND_API_KEY=your_resend_key
NOTIFICATION_EMAIL=info@genesisai.systems

# Business Details
BUSINESS_NAME=Genesis AI Systems
FOUNDER_NAME=Trendell Fordham
BUSINESS_PHONE=(313) 400-2575
BUSINESS_EMAIL=info@genesisai.systems
BUSINESS_WEBSITE=https://genesisai.systems
CALENDLY_URL=https://calendly.com/genesisai-info-ptmt/free-ai-demo-call

# Telegram (bot control + alerts)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# HubSpot (pipeline system of record)
HUBSPOT_ACCESS_TOKEN=your_hubspot_private_app_token

# HoneyBook (proposals + contracts + intake — system of record)
HONEYBOOK_API_KEY=your_honeybook_api_key

# Stripe (payments)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_signing_secret

# Google Sheets — NOT part of locked V1 stack. HubSpot is the pipeline SOR.
# GOOGLE_SHEET_ID and GOOGLE_SERVICE_ACCOUNT intentionally omitted.

# n8n (workflow orchestration — async glue between systems)
# Used by GitHub Actions workflows that dispatch to n8n webhooks (Calendly, Stripe triggers)
N8N_WEBHOOK_URL=https://n8n.genesisai.systems

# Demo server
DEMO_SERVER_URL=https://genesis-ai-systems-demo.onrender.com

# Hunter.io (optional — email discovery — NOT part of V1 critical path)
# Activate only when lead volume is consistent and manual email sourcing is a bottleneck
# HUNTER_API_KEY=your_hunter_api_key

# GitHub (for workflow dispatch from Telegram bot)
GITHUB_TOKEN=your_github_personal_access_token
