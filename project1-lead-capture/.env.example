# Genesis AI Systems — Project 1: Lead Capture + AI Scoring
# Example Production Environment Variables
#
# Note: n8n must be deployed to DigitalOcean at n8n.genesisai.systems
# Webhooks and integrations must reference your LIVE production endpoints.
#
# Google Sheets: Use your production sheet (not the test/dev sheet).
# Gmail: Must send from info@genesisai.systems via production OAuth credentials.

# Application
NODE_ENV=production
PORT=3000

# n8n Webhook endpoint (LIVE - ensure n8n is deployed to DigitalOcean and accessible)
LEAD_WEBHOOK_URL=https://n8n.genesisai.systems/webhook/lead-incoming

# Google Sheets (Production Sheet ID and Name)
GOOGLE_SHEETS_CLIENT_EMAIL=your-google-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_SPREADSHEET_ID=your_production_spreadsheet_id
GOOGLE_SHEETS_SHEET_NAME=Genesis AI Systems — Leads

# Gmail (must send from info@genesisai.systems)
GMAIL_CLIENT_ID=your_gmail_client_id
GMAIL_CLIENT_SECRET=your_gmail_client_secret
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token
GMAIL_FROM_ADDRESS=info@genesisai.systems

# Twilio (For SMS alerts)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
ADMIN_ALERT_PHONE=+13134002575

# OpenAI (for lead scoring prompt)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LEAD_SCORING_PROMPT="Score this lead for sales readiness, 1-10, based on their message, business, and intent."

# Allowed origins for CORS
CORS_ORIGIN=https://genesisai.systems

# Calendly link to use in outbound emails and responses
CALENDLY_LINK=https://calendly.com/genesisai-info-ptmt/free-ai-demo-call

# Branding/Agency information
AGENCY_NAME=Genesis AI Systems
AGENCY_WEBSITE=https://genesisai.systems
FOUNDER_NAME=Trendell Fordham
FOUNDER_EMAIL=info@genesisai.systems

# Logging settings
LOG_LEVEL=info
ENABLE_USAGE_LOG=true
